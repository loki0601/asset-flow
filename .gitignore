# Telegram channel state — contains bot token, allowlist, inbox cache
.telegram-state/

# Claude Code local settings & session state
.claude/

# Local device DB backups (may contain personal financial data)
.backups/

# OS
.DS_Store

# Env files
.env
.env.local
.env.*.local

# Service account keys / private credentials — NEVER commit
/secrets/
*-firebase-adminsdk-*.json
*service-account*.json

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build output
dist/
build/
*.tsbuildinfo
.next/
out/

# Capacitor / Android
android/.gradle/
android/app/build/
android/build/
android/local.properties
android/.idea/
android/captures/
android/app/release/
*.apk
*.aab

# Server-side SQLite (history tracking) — runtime data, never committed
/data/

# Logs
*.log

# Playwright local artifacts (snapshots / console captures)
.playwright-mcp/
test-results/
playwright-report/

# Local screenshot scratch (root-level *.png from playwright/iteration)
/*.png

# Python venv for catalog scripts
.venv/
__pycache__/
*.pyc
