{
  "name": "asset-flow",
  "version": "0.1.0",
  "description": "Family asset management web + android app",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev -p 3500",
    "build": "bash scripts/build-and-preserve.sh",
    "build:raw": "next build",
    "start": "next start -p 3500",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node --import tsx src/server/db/migrate.ts",
    "cap:sync": "cap sync android",
    "cap:open": "cap open android",
    "cap:build": "cd android && ./gradlew assembleDebug",
    "cap:install": "adb -s 192.168.0.142:5555 install -r android/app/build/outputs/apk/debug/app-debug.apk"
  },
  "dependencies": {
    "@capacitor/android": "^6.1.2",
    "@capacitor/app": "^6.0.3",
    "@capacitor/core": "^6.1.2",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/preferences": "^6.0.4",
    "@capacitor/push-notifications": "^8.1.1",
    "@capacitor/status-bar": "^8.0.2",
    "@libsql/client": "^0.17.3",
    "@paralleldrive/cuid2": "^2.2.0",
    "drizzle-orm": "^0.31.0",
    "firebase-admin": "^13.10.0",
    "lucide-react": "^0.400.0",
    "next": "^15.0.0",
    "pino": "^8.17.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "simple-icons": "^16.21.0",
    "sql.js": "^1.14.1",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/sql.js": "^1.4.11",
    "autoprefixer": "^10.4.20",
    "better-sqlite3": "^12.9.0",
    "drizzle-kit": "^0.24.2",
    "eslint": "^8.56.0",
    "eslint-config-next": "^15.0.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.2",
    "vitest": "^2.1.8"
  }
}
