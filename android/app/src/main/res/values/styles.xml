<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <!--
        Post-splash theme.  windowBackground is the landing drawable
        (brand bg + aurora mark + wordmark baked in), so the moment the
        system splash dismisses the activity window already shows the
        landing — no flash of pure brand colour before the WebView paints.
    -->
    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowBackground">@drawable/landing</item>
    </style>

    <!--
        Launch theme.  androidx core-splashscreen backport for Android ≤ 11.
        On Android 12+ the system uses the values-v31 override which sets
        the splash icon to a 1×1 transparent PNG so no system icon shows.
    -->
    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/brand_splash_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/empty_icon</item>
        <item name="postSplashScreenTheme">@style/AppTheme.NoActionBar</item>
    </style>
</resources>
