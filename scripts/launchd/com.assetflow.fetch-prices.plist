<?xml version="1.0" encoding="UTF-8"?>
<!--
  launchd job: run scripts/fetch-prices.py once per day at 15:35 KST.

  Install (one-time):
    bash scripts/launchd/install.sh

  Inspect / control:
    launchctl list | grep com.assetflow
    launchctl print gui/$(id -u)/com.assetflow.fetch-prices
    launchctl stop com.assetflow.fetch-prices
    launchctl unload ~/Library/LaunchAgents/com.assetflow.fetch-prices.plist

  Why 15:35 and not 15:30?
    KRX closes 15:30, but FDR's snapshot needs a few minutes to stabilise.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.assetflow.fetch-prices</string>

  <key>ProgramArguments</key>
  <array>
    <string>__PROJECT_DIR__/.venv/bin/python</string>
    <string>__PROJECT_DIR__/scripts/fetch-prices.py</string>
  </array>

  <key>WorkingDirectory</key>
  <string>__PROJECT_DIR__</string>

  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>15</integer>
    <key>Minute</key>
    <integer>35</integer>
  </dict>

  <key>StandardOutPath</key>
  <string>__PROJECT_DIR__/data/fetch-prices.log</string>
  <key>StandardErrorPath</key>
  <string>__PROJECT_DIR__/data/fetch-prices.log</string>

  <key>RunAtLoad</key>
  <false/>
</dict>
</plist>
